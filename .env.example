# Copy this file to .env and fill in your values.
# Never commit .env to version control.

# --- Runtime switch ---
# true  = use local Ollama (default, for offline use)
# false = use HF Inference API (for HF Spaces deployment)
USE_OLLAMA=true

# --- Ollama settings (used when USE_OLLAMA=true) ---
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=gemma4:e4b

# --- Hugging Face settings (used when USE_OLLAMA=false) ---
HF_TOKEN=
HF_MODEL_ID=google/gemma-4-e4b-it

# --- Whisper STT settings ---
WHISPER_MODEL_SIZE=small
WHISPER_LANGUAGE=hi

# --- Gradio settings ---
GRADIO_SERVER_PORT=7860
GRADIO_SHARE=false
